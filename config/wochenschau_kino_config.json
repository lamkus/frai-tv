  "matching": {
    "_note": "How to match interstitials to Wochenschau episodes by date",
    "algorithm": "weighted_era_match",
    "rules": {
      "exact_year_weight": 10,
      "adjacent_year_weight": 7,
      "same_decade_weight": 4,
      "any_era_weight": 1,
      "max_year_distance": 15,
      "variety_bonus": 3,
      "category_repeat_penalty": 5,
      "soundie_min_probability": 0.4,
      "soundie_max_probability": 0.7,
      "_note_soundies": "Between 40-70% of interstitial slots should be Soundies (like real 1940s cinema)"
    },
    "per_episode_interstitials": {
      "min": 1,
      "max": 3,
      "default": 2,
      "_note": "Each Wochenschau gets 1-3 interstitials. Default: 1 before + 1 after"
    },
    "preferred_types_by_era": {
      "1939": [
        "betty_boop_late",
        "silly_symphonies",
        "vintage_commercials",
        "fleischer_color",
        "comicolor"
      ],
      "1940": [
        "vintage_commercials",
        "betty_boop_late",
        "soundies",
        "fleischer_color",
        "porky_pig"
      ],
      "1941": ["soundies", "vintage_commercials", "superman_fleischer", "porky_pig"],
      "1942": [
        "soundies",
        "vintage_commercials",
        "superman_fleischer",
        "porky_pig",
        "wartime_shorts"
      ],
      "1943": [
        "soundies",
        "vintage_commercials",
        "superman_fleischer",
        "wartime_shorts",
        "porky_pig"
      ],
      "1944": ["soundies", "vintage_commercials", "porky_pig", "wartime_shorts"],
      "1945": ["soundies", "vintage_commercials", "casper", "wartime_shorts"]
    }
  },

  "program_format": {
    "_note": "The 'Kino-Programm' sequence per Wochenschau episode",
    "standard": {
      "sequence": ["soundie_or_cartoon", "wochenschau", "cartoon_or_soundie"],
      "total_block_min": 25,
      "total_block_max": 45,
      "_note": "Soundie (3min) + Wochenschau (20min) + Cartoon (7min) = ~30min block"
    },
    "extended": {
      "sequence": ["soundie", "cartoon", "wochenschau", "soundie"],
      "total_block_min": 35,
      "total_block_max": 55,
      "_note": "Used when Superman is available: Soundie + Superman + Wochenschau + Soundie"
    },
    "minimal": {
      "sequence": ["soundie", "wochenschau"],
      "total_block_min": 20,
      "total_block_max": 35,
      "_note": "Fallback when interstitial pool is thin"
    },
    "active_format": "standard"
  },

